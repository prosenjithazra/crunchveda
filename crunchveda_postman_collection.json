      "description": "Paste your JWT access token here after login"
    },
    {
      "key": "CATEGORY_ID",
      "value": "",
      "type": "string"
    },
    {
      "key": "PRODUCT_ID",
      "value": "",
      "type": "string"
    },
    {
      "key": "PRODUCT_SLUG",
      "value": "mamra-almonds",
      "type": "string"
    },
    {
      "key": "CATEGORY_SLUG",
      "value": "almonds",
      "type": "string"
    },
    {
      "key": "ORDER_ID",
      "value": "",
      "type": "string"
    },
    {
      "key": "REVIEW_ID",
      "value": "",
